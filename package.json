{
  "name": "ajo-circle",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "type-check": "npm run type-check --workspace=frontend",
    "test:contracts": "cd contracts && forge test -vvv",
    "test:frontend": "npm run test --workspace=frontend",
    "forge:build": "cd contracts && forge build",
    "forge:fmt": "cd contracts && forge fmt",
    "forge:snapshot": "cd contracts && forge snapshot",
    "deploy:alfajores": "cd contracts && forge script script/Deploy.s.sol --rpc-url celo_alfajores --broadcast --verify"
  },
  "engines": {
    "node": ">=20"
  }
}
