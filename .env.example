# =============================================================================
# Ajo Circle — Frontend environment (example / template)
# Copy this file to frontend/.env.local and fill in your values.
# Never commit frontend/.env.local — it may contain sensitive app credentials.
# =============================================================================
#
# NEXT_PUBLIC_* variables are embedded into the client bundle at build time.
# Do NOT put secrets here — anything prefixed NEXT_PUBLIC_ is visible to users.
# =============================================================================

# ─── Privy (wallet auth + embedded wallets) ───────────────────────────────────
# Your Privy application ID.
# 1. Sign up at https://privy.io
# 2. Create a new app in the dashboard
# 3. Copy the App ID from Settings → App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# ─── Chain ────────────────────────────────────────────────────────────────────
# Celo mainnet chain ID: 42220. (Celo Sepolia was 11142220)
# Reference: https://chainlist.org/chain/42220
NEXT_PUBLIC_CHAIN_ID=42220

# ─── RPC ──────────────────────────────────────────────────────────────────────
# JSON-RPC endpoint the frontend uses for read calls (wagmi public client).
# Celo mainnet public endpoint: https://forno.celo.org
NEXT_PUBLIC_RPC_URL=https://forno.celo.org

# ─── Contract addresses ──────────────────────────────────────────────────────
# Address of the deployed AjoCircle factory contract on Celo Mainnet.
NEXT_PUBLIC_AJO_FACTORY_ADDRESS=0xE869345337E1cec4A84De62dA356259C262CB3B5

# Address of the yield vault contract on Celo Mainnet.
NEXT_PUBLIC_YIELD_VAULT_ADDRESS=0x5d872B5fe7334577d15Acbd7E62Dd954930eC85D

# ─── GoodDollar identity ──────────────────────────────────────────────────────
# Controls which GoodDollar identity contract the SDK targets.
# production → Celo mainnet
NEXT_PUBLIC_GOODDOLLAR_ENV=production

# GoodDollar Identity contract address.
# Celo Mainnet: 0xC361A6E67822a0EDc17D899227dd9FC50BD62F42
NEXT_PUBLIC_IDENTITY_ADDRESS=0xC361A6E67822a0EDc17D899227dd9FC50BD62F42

# ─── Token addresses ──────────────────────────────────────────────────────────
# GoodDollar (G$) token contract address.
# Celo mainnet: 0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A
NEXT_PUBLIC_G_DOLLAR_ADDRESS=0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A