# =============================================================================
# Ajo Circle — Contracts environment (example / template)
# Copy this file to contracts/.env and fill in your values.
# Never commit contracts/.env — it holds real secrets.
# =============================================================================

# ─── Deployer wallet ──────────────────────────────────────────────────────────
# The private key of the account that will sign deployment transactions.
# Generate a fresh deployer wallet: `cast wallet new`
# Fund it with testnet CELO: https://faucet.celo.org/alfajores
PRIVATE_KEY=

# ─── Contract verification ────────────────────────────────────────────────────
# API key used by forge to verify contracts on Celoscan after deployment.
# Create a free account and generate a key at: https://celoscan.io/myapikey
CELOSCAN_API_KEY=

# ─── RPC endpoints ────────────────────────────────────────────────────────────
# Public Celo mainnet RPC provided by the Celo Foundation (no key required).
# For production, consider a dedicated node (QuickNode, Infura, Ankr, etc.)
CELO_RPC=https://forno.celo.org

# Public Celo Sepoli testnet RPC provided by the Celo Foundation (no key required).
# Chain ID: 11142220
CELO_TESTNET_RPC=https://forno.celo-sepolia.celo-testnet.org
