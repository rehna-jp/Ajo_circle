# =============================================================================
# Ajo Circle — Frontend environment (example / template)
# Copy this file to frontend/.env.local and fill in your values.
# Never commit frontend/.env.local — it may contain sensitive app credentials.
# =============================================================================
#
# NEXT_PUBLIC_* variables are embedded into the client bundle at build time.
# Do NOT put secrets here — anything prefixed NEXT_PUBLIC_ is visible to users.
# =============================================================================

# ─── Privy (wallet auth + embedded wallets) ───────────────────────────────────
# Your Privy application ID.
# 1. Sign up at https://privy.io
# 2. Create a new app in the dashboard
# 3. Copy the App ID from Settings → App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# ─── Chain ────────────────────────────────────────────────────────────────────
# Celo Alfajores testnet chain ID. Switch to 42220 for Celo mainnet.
# Reference: https://chainlist.org/chain/44787
NEXT_PUBLIC_CHAIN_ID=

# ─── RPC ──────────────────────────────────────────────────────────────────────
# JSON-RPC endpoint the frontend uses for read calls (wagmi public client).
# The public Forno endpoint is fine for development and low-traffic production.
# For high-traffic production use a dedicated provider (QuickNode, Infura, etc.)
NEXT_PUBLIC_RPC_URL=

# ─── Contract addresses (Celo Alfajores, chainId 44787) ──────────────────────
# Address of the deployed AjoCircle factory contract.
# Populated automatically after: npm run deploy:alfajores
# See the deployment output or contracts/broadcast/ for the address.
NEXT_PUBLIC_AJO_FACTORY_ADDRESS=

# Address of the yield vault contract (e.g. a Ubeswap / Mento vault for G$).
# Leave as zero-address until the vault contract is deployed.
NEXT_PUBLIC_YIELD_VAULT_ADDRESS=

# ─── GoodDollar identity ──────────────────────────────────────────────────────
# Controls which GoodDollar identity contract the SDK targets.
# staging    → while building/testing on Alfajores
# production → Celo mainnet (set this before going live)
NEXT_PUBLIC_GOODDOLLAR_ENV=

# ─── Token addresses ──────────────────────────────────────────────────────────
# GoodDollar (G$) token contract address.
# Celo mainnet: 0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A
# Alfajores:    no official address — deploy MockGDollar from contracts/test/ for local testing
NEXT_PUBLIC_G_DOLLAR_ADDRESS=
